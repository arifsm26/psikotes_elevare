# --- Fungsi untuk Laporan / Hasil ---

def get_all_participants(db: Session, skip: int = 0, limit: int = 100):
    """Mengambil daftar semua peserta."""
    return db.query(models.Participant).order_by(models.Participant.id.desc()).offset(skip).limit(limit).all()

def get_participant_details(db: Session, participant_id: int):
    """Mengambil detail satu peserta."""
    return db.query(models.Participant).filter(models.Participant.id == participant_id).first()

def get_participant_answers_for_export(db: Session, participant_id: int):
    """Mengambil semua jawaban peserta untuk di-export."""
    return db.query(
        models.ParticipantAnswer.id,
        models.Test.name.label("test_name"),
        models.Question.text.label("question_text"),
        models.ParticipantAnswer.answer_text,
        models.AnswerOption.text.label("selected_answer"),
        models.AnswerOption.score.label("answer_score")
    ).select_from(models.ParticipantAnswer)\
     .join(models.Question, models.ParticipantAnswer.question_id == models.Question.id)\
     .join(models.Test, models.Question.test_id == models.Test.id)\
     .outerjoin(models.AnswerOption, models.ParticipantAnswer.selected_option_id == models.AnswerOption.id)\
     .filter(models.ParticipantAnswer.participant_id == participant_id).all()

def get_participant_answers_for_test_export(db: Session, participant_id: int, test_id: int):
    """Mengambil jawaban peserta per tes untuk di-export."""
    return db.query(
        models.ParticipantAnswer.id,
        models.Question.text.label("question_text"),
        models.ParticipantAnswer.answer_text,
        models.AnswerOption.text.label("selected_answer"),
        models.AnswerOption.score.label("answer_score")
    ).select_from(models.ParticipantAnswer)\
     .join(models.Question, models.ParticipantAnswer.question_id == models.Question.id)\
     .outerjoin(models.AnswerOption, models.ParticipantAnswer.selected_option_id == models.AnswerOption.id)\
     .filter(
        models.ParticipantAnswer.participant_id == participant_id,
        models.Question.test_id == test_id
    ).all()



def delete_participant(db: Session, participant_id: int):
    db_participant = db.query(models.Participant).filter(models.Participant.id == participant_id).first()
    if db_participant:
        # Hapus semua data anak terlebih dahulu
        db.query(models.ParticipantAnswer).filter(models.ParticipantAnswer.participant_id == participant_id).delete(synchronize_session=False)
        db.query(models.TestSession).filter(models.TestSession.participant_id == participant_id).delete(synchronize_session=False)
        # Baru hapus induknya
        db.delete(db_participant)
        db.commit()
        return True
    return False
